state/rotation_predictions.json
state/ocr_manual_queue.json
state/undated_media.json
state/video_dates.json
# state/shards/: ignore input shards (regenerable from orchestrate_ocr.py);
# track result JSONs — those are the expensive OCR output, ~2 KB/shard.
state/shards/**/shard_*.json
!state/shards/**/*_result.json
state/bench/
output/vlm_bench_*

